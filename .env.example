# ---- Broadcast Box ----
# Internal base URL of the Broadcast Box API (no trailing slash).
# In the example compose this is the private service name.
BROADCAST_BOX_API_URL=http://broadcast-box:8080

# Admin token in CLEARTEXT. The watcher base64-encodes it automatically before
# sending it as `Authorization: Bearer <base64(token)>`.
# Must equal Broadcast Box's FRONTEND_ADMIN_TOKEN.
BROADCAST_BOX_ADMIN_TOKEN=changeme

# Public host shown in the temporary group name, e.g. "🔴 stream.example.com/azn".
# Scheme (https://) and trailing slashes are stripped automatically.
PUBLIC_STREAM_HOST=stream.example.com

# ---- TeamSpeak ServerQuery ----
TEAMSPEAK_HOST=teamspeak
# ServerQuery (RAW) port.
TEAMSPEAK_QUERY_PORT=10011
# Voice port of the virtual server to select.
TEAMSPEAK_SERVER_PORT=9987
TEAMSPEAK_QUERY_USERNAME=serveradmin
TEAMSPEAK_QUERY_PASSWORD=changeme
# Nickname the query client connects with.
TEAMSPEAK_QUERY_NICKNAME=broadcast-watcher

# ---- Watcher ----
# Reconcile interval in milliseconds.
POLL_INTERVAL_MS=10000
# Prefix for the temporary group name.
GROUP_PREFIX=🔴
# debug | info | warn | error
LOG_LEVEL=info
