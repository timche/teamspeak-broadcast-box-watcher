# Loaded automatically by `bun test` (NODE_ENV=test). `src/config.ts` validates
# `process.env` on import, so these dummy values let the module load; tests then
# import the resulting `config` directly. No secrets — safe to commit.
BROADCAST_BOX_API_URL=http://broadcast-box:8080
BROADCAST_BOX_ADMIN_TOKEN=secret
PUBLIC_STREAM_HOST=stream.example.com
TEAMSPEAK_HOST=teamspeak
TEAMSPEAK_QUERY_PASSWORD=pw
